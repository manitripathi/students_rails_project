<h1>Student List</h1>

<%= @students.inspect %>

<table border="1">
  <tr>
    <th>First Name</th>
    <th>Last Name</th>
    <th>Email</th>
    <th>Phone</th>
  </tr>
  <% @students.each do |student| %>
    <tr>
    <td><%= student[:first_name] %></td>
    <td><%= student[:last_name] %></td>
    <td><%= student[:email] %></td>
    <td><%= student.phone %></td>
  </tr>
  <% end %>
</table>

<br/><br/>
<a href="/students/new">Add New Student</a>

<h1>Student List</h1>

<table border="1">
  <tr>
    <th>First Name</th>
    <th>Last Name</th>
    <th>Email</th>
    <th>Phone</th>
    <th>Actions</th>
  </tr>
  <% @students.each do |student| %>
    <tr>
      <td><%= student.first_name %></td>
      <td><%= student.last_name %></td>
      <td><%= student.email %></td>
      <td><%= student.phone %></td>
      <td>
        <%= link_to "Edit", edit_student_path(student) %> |
        <%= form_with model: student, method: :delete do %>
          <%= submit_tag "Delete", data: { confirm: "Are you sure?" } %>
        <% end %>
    
      </td>
    </tr>
  <% end %>
</table>
